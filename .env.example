# Copy to .env and fill in values from your Supabase project
# (Project Settings → API in the Supabase dashboard).

# Your project's REST URL, e.g. https://abcdefg.supabase.co
VITE_SUPABASE_URL=

# The "anon public" key — safe to ship in the client bundle; access is
# gated by the RLS policies defined in supabase/schema.sql.
VITE_SUPABASE_ANON_KEY=
